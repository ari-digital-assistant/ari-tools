# Copy this to .env and fill in your values. .env is gitignored.
#
# Note: HF_TOKEN is no longer needed for training runs. The instance
# fetches it from AWS Secrets Manager (ari-functiongemma/hf-token) via
# its instance profile. Training runs need no secrets in .env or env vars.
#
# This file is only for optional AWS config overrides.

# AWS region for the spot instance
# AWS_REGION=eu-west-2

# Instance type
# INSTANCE_TYPE=g6.xlarge

# SSH key pair name (auto-created if missing)
# AWS_KEY_NAME=ari-functiongemma

# Security group name (auto-created if missing)
# AWS_SG_NAME=ari-functiongemma-train

# Instance profile that grants read access to the HF token secret
# AWS_INSTANCE_PROFILE=ari-functiongemma-instance

# Secrets Manager ID holding the HuggingFace token
# HF_SECRET_ID=ari-functiongemma/hf-token
