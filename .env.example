# Copy this to .env and fill in your values. .env is gitignored.

# HuggingFace token with Gemma model access.
# Get one at https://huggingface.co/settings/tokens
# Make sure you've accepted the Gemma license at
# https://huggingface.co/google/functiongemma-270m-it
HF_TOKEN=hf_your_token_here

# Optional AWS overrides (defaults shown)
# AWS_REGION=eu-west-2
# INSTANCE_TYPE=g5.xlarge
# AWS_KEY_NAME=ari-functiongemma
# AWS_SG_NAME=ari-functiongemma-train
